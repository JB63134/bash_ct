#!/usr/bin/env bash
#-----------------------------------------------------------------------------------------------
# Playground aka pg                                                                  
# Purpose: place to test new crap.  this time it's a Command Resolution & Shadowing Report based on 
# the resolver function in ct       
#-----------------------------------------------------------------------------------------------
# Copyright (c) 2026 John Blair
# Licensed under the MIT License. See LICENSE file for details.        
#-----------------------------------------------------------------------------------------------

if [[ -z "${BASH_VERSION:-}" ]]; then
    printf "pg must be sourced or executed by bash.\n" >&2
    return 1
fi

__PG_version=4.3.0
__PG_needed_deps=(grep file cut head readlink readelf awk)
__PG_optional_deps=(tput)


complete -F _pg_completion ct

#------------------------------------------------------------------------
# Function: ct
# Purpose : User-facing entry point.
#
# Behavior:
# â€˘ Parses command-line options
# â€˘ Rejects path-based input
# â€˘ Dispatches to human-readable or JSON output
#
# Exit codes:
# â€˘ 0  â†’ successful resolution
# â€˘ 1  â†’ command not found or invalid input
#------------------------------------------------------------------------
pg() {

    while [[ $# -gt 0 ]]; do
        local arg="$1"

        case "$arg" in
            --help)
                _pg_usage
                return 0
                ;;
            --version)
                _pg_ver
                return 0
                ;;
            -*)  # short flags, possibly combined like -jx
                local i
                for (( i=1; i<${#arg}; i++ )); do
                    local flag="${arg:i:1}"
                    case "$flag" in
                        h)
                            _pg_usage
                            return 0
                            ;;
                        v)
                            _pg_ver
                            return 0
                            ;;
                        *)
                            printf "Unknown option: -%s\n" "$flag" >&2
                            return 1
                            ;;
                    esac
                done
                shift
                ;;
            *)
                break  # first non-option argument (command)
                ;;
        esac
    done
    
    # Dispatch output
    _pg_conflicts
}

#------------------------------------------------------------------------
# Function: _pg_resolve
# Purpose : Core command resolution engine.
#
# Inputs:
#   $1 â†’ command name (bare token, no path)
#   $2 â†’ nameref to associative array for resolution results (RES)
#   $3 â†’ nameref to indexed array for PATH scan results (PATH_ENTRIES)
#
# Outputs (RES associative array):
#   command          â†’ original command string
#   bash_type        â†’ alias|function|keyword|builtin|path|notfound
#   shadowed_fs      â†’ true if filesystem executables are unreachable
#
#   alias_*          â†’ alias detection and definition
#   function_*       â†’ function location and line
#   builtin_*        â†’ builtin state (enabled/disabled)
#   keyword_found    â†’ keyword match
#
#   kernel_*         â†’ execution target details (PATH only)
#
# Notes:
# â€˘ Resolution precedence follows Bash rules, not filesystem order.
# â€˘ PATH scanning records *all* candidates, not just the winner.
#------------------------------------------------------------------------
# shellcheck disable=SC2154
_pg_resolve() {

__PG_KEYWORDS=($(compgen -k))
__PG_BUILTINS=($(compgen -b))
__PG_POSIX_SPECIAL_BUILTINS=(
    :
    .
    break
    continue
    eval
    exec
    exit
    export
    readonly
    return
    set
    shift
    times
    trap
    unset
)

    local cmd="$1"
    local -n R="$2"      # associative result
    local -n P="$3"      # indexed PATH entries
    local alias_out
    
    # shellcheck disable=SC2034  
    R=()
    P=()

    RES[command]="$cmd"
    RES[bash_type]="notfound"
    RES[shadowed_fs]=false
    RES[function_shadowed]=false
    RES[builtin_shadowed]=false
    RES[keyword_shadowed_alias]=false
    RES[alias_shadowed]=false
    RES[posix_mode]=false
    
    # ------------------------------------------------------------
    # Edge cases
    # ------------------------------------------------------------
    case "$cmd" in
        '{'|'}'|'('|')'|'[['|']]'|']'|'.')
            RES[keyword_found]=true
            RES[bash_type]="keyword"
            ;;
    esac

    # ------------------------------------------------------------
    # Alias
    # ------------------------------------------------------------
    if alias "$cmd" &>/dev/null; then

        alias_out=$(alias -- "$cmd" 2>/dev/null) || return

        RES[alias_found]=true
        RES[alias_def]="$alias_out"
        RES[bash_type]="alias"
    else
        RES[alias_found]=false
    fi

    # ------------------------------------------------------------
    # POSIX special builtin (pre-function precedence)
    # ------------------------------------------------------------
    if (( __PG_POSIX_MODE )) && compgen -b | grep -Fxq -- "$cmd"; then
        if _pg_is_posix_special_builtin "$cmd"; then
            RES[builtin_found]=true
            RES[posix_special]=true
        fi
    fi

    if (( __PG_POSIX_MODE )); then
        RES[posix_mode]=true
    fi
  
    # ------------------------------------------------------------
    # Function (skip if POSIX special builtin already resolved)
    # ------------------------------------------------------------
    if [[ ${RES[posix_special]} != true ]] && declare -F "$cmd" &>/dev/null; then
        R[function_found]=true

        local line file
        shopt -q extdebug || { shopt -s extdebug; local _ext=1; }
        read -r _ line file <<<"$(declare -F "$cmd")"
        [[ $_ext ]] && shopt -u extdebug

        R[function_file]="${file:-interactive shell}"
        R[function_line]="$line"

        # Mark shadowed if higher precedence exists (alias or keyword)
        if [[ ${R[bash_type]} =~ ^(alias|keyword|builtin)$ ]]; then
            R[function_shadowed]=true
        else
            R[bash_type]="function"
            R[function_shadowed]=false
        fi
    else
        R[function_found]=false
    fi

    # ------------------------------------------------------------
    # Keyword (higher precedence than builtin)
    # ------------------------------------------------------------
    if _pg_cache_compgen "$cmd" __PG_KEYWORDS; then
        RES[keyword_found]=true
        RES[bash_type]="keyword" 
    else
        RES[keyword_found]=false
    fi

    if [[ ${RES[keyword_found]} == true && ${RES[alias_found]} == true ]]; then
        RES[keyword_shadowed_alias]=true
    fi
    
    # ------------------------------------------------------------
    # Builtin
    # ------------------------------------------------------------
    if _pg_cache_compgen "$cmd" __PG_BUILTINS; then
        RES[builtin_found]=true

        # enabled/disabled state
        if enable -n | grep -Fxq -- "enable -n $cmd"; then
            RES[builtin_state]="disabled"
        else
            RES[builtin_state]="enabled"
        fi

        # shadowed only if enabled and something higher-precedence exists
    if [[ ${RES[builtin_state]} == "enabled" && \
          ${RES[bash_type]} =~ ^(alias|function|keyword)$ && \
          ( __PG_POSIX_MODE -eq 0 || ! $(_pg_is_posix_special_builtin "$cmd") ) ]]; then
        RES[builtin_shadowed]=true
    fi

        # builtin wins only if enabled and not shadowed, and nothing else resolved yet
        if [[ ${RES[builtin_state]} == "enabled" && ${RES[builtin_shadowed]} == false && ${RES[bash_type]} == "notfound" ]]; then
            RES[bash_type]="builtin"
            RES[bash_winner]="$cmd"
        fi
    else
        RES[builtin_found]=false
        RES[builtin_state]=null
        RES[builtin_shadowed]=false
    fi

    # ------------------------------------------------------------
    # POSIX special builtin precedence
    # ------------------------------------------------------------
    if (( __PG_POSIX_MODE )) && compgen -b | grep -Fxq -- "$cmd"; then
        if _pg_is_posix_special_builtin "$cmd"; then
            RES[builtin_found]=true
            # POSIX special builtin shadows function
            if [[ ${RES[function_found]} == true ]]; then
                RES[function_shadowed]=true
            fi
        fi
    fi

    # Builtin only wins if no higher-precedence Bash entity already resolved
    if [[ ${RES[builtin_found]} == true &&
        ${RES[builtin_state]} == "enabled" &&
        ${RES[builtin_shadowed]} == false &&
        ${RES[bash_type]} == "notfound" ]]; then
        RES[bash_type]="builtin"
        RES[bash_winner]="$cmd"
    fi

    # ------------------------------------------------------------
    # PATH scan
    # PATH entry encoding format (PATH_ENTRIES):
    #   "dir|state|target|shadow"
    #
    #   dir     â†’ PATH directory
    #   state   â†’ notfound | file | symlink
    #   target  â†’ resolved target (for symlink), empty otherwise
    #   shadow  â†’ true if this entry is unreachable by bare invocation
    # ------------------------------------------------------------
    local found_path=""
    local path_winner_seen=0

    IFS=: read -ra _dirs <<<"$PATH"
    for d in "${_dirs[@]}"; do
        local p="$d/$cmd"
        
        # Skip if not executable
        if [[ ! -x "$p" || ! -f "$p" ]]; then
            P+=("$d|notfound||false")
            continue
        fi

        local state=file target="$p"
        if [[ -L "$p" ]]; then
            state=symlink
            target="$(readlink "$p")"
        fi

        local shadow=false
        # Mark as shadowed if a higher-priority Bash resolution exists
        if [[ ${RES[bash_type]} =~ ^(alias|function|builtin|keyword)$ ]]; then
            shadow=true
            RES[shadowed_fs]=true
        elif (( path_winner_seen )); then
            shadow=true
        else
            path_winner_seen=1
            # Only set bash_type=path if no higher-priority type is set
            [[ ${RES[bash_type]} == "notfound" ]] && RES[bash_type]="path"
            found_path="$p"
        fi

        P+=("$d|$state|$target|$shadow")
    done

    # ------------------------------------------------------------
    # Kernel execution details + alternatives detection
    # ------------------------------------------------------------
    if [[ ${RES[bash_type]} == "path" && -n $found_path ]]; then
        RES[kernel_path]="$found_path"
        RES[kernel_canonical]="$(readlink -f "$found_path")"
        RES[elf_interp]=""
        RES[shebang]=""

        # ELF interpreter (if ELF binary)
        if file "${RES[kernel_canonical]}" 2>/dev/null | grep -q ELF; then
            RES[elf_interp]="$(readelf -l "${RES[kernel_canonical]}" 2>/dev/null \
                          | awk '/interpreter/ {gsub(/[][]/, "", $NF); print $NF}')"
        fi

        # Shebang (if script)
        if head -1 "${RES[kernel_canonical]}" 2>/dev/null | grep -q '^#!'; then
            RES[shebang]="$(head -1 "${RES[kernel_canonical]}" | cut -c3-)"
        fi

        # Symlink chain (safe string for JSON)
        local chain=()
        local x="$found_path"
        while [[ -L "$x" ]]; do
            local y
            y="$(readlink "$x")"
            chain+=("$x -> $y")
            x="$y"
        done
        RES[kernel_chain]=$(printf '%s\n' "${chain[@]}")  # newline-delimited string

        # Alternatives detection
        RES[alternatives]=false
        RES[alternatives_link]=null
        RES[alternatives_target]=null

        x="$found_path"
        while [[ -L "$x" ]]; do
            if [[ "$x" == /etc/alternatives/* ]]; then
                RES[alternatives]=true
                RES[alternatives_link]="$x"
                RES[alternatives_target]="$(readlink -f "$x")"
                break
            fi
            x="$(readlink -f "$x")"
        done
    fi
  
    # special edge case
    if [[ $cmd == "." ]]; then
        RES[bash_type]="keyword"
        RES[keyword_found]=true
        RES[builtin_shadowed]=false
    fi
    
    : "${RES[bash_type]:=notfound}"
    return 0
}

#------------------------------------------------------------------------
# Function: _pg_cache_compgen "$cmd" __PG_KEYWORDS
# Purpose: avoid abusing compgen for a report mode (multiple commands at once)
#------------------------------------------------------------------------
_pg_cache_compgen() {
    local needle="$1"
    local -n haystack="$2"
    local item

    for item in "${haystack[@]}"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

#------------------------------------------------------------------------
# Function: _pg_is_posix_special_builtin
# Purpose: check if command is a posix special builtin
#------------------------------------------------------------------------
_pg_is_posix_special_builtin() {
    local b
    for b in "${__PG_POSIX_SPECIAL_BUILTINS[@]}"; do
        [[ $b == "$1" ]] && return 0
    done
    return 1
}

#------------------------------------------------------------------------
# Function: _pg_usage
# Purpose : Display usage information and examples for the `h` command analyzer.
#------------------------------------------------------------------------
_pg_usage() {
    cat <<'EOF'

    Usage:
      pg [option] command
    
    Playground for stuff 
    
    Command Resolution & Shadowing Report

    Options:
      -h, --help        Show this help text
      -v, --version     Show version and license information

EOF
}

#------------------------------------------------------------------------
# Function: _pg_ver
# Purpose : Display version information.
#------------------------------------------------------------------------
_pg_ver() {

    printf "\n     pg v%s  â€” Command Resolution & Shadowing Report \n" "$__PG_version"
    cat <<'EOF'
    
     MIT License
     
     Copyright (c) 2026 John Blair

     Permission is hereby granted, free of charge, to any person obtaining a copy
     of this software and associated documentation files (the "Software"), to deal
     in the Software without restriction, including without limitation the rights
     to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
     copies of the Software, and to permit persons to whom the Software is
     furnished to do so, subject to the following conditions:

     The above copyright notice and this permission notice shall be included in all
     copies or substantial portions of the Software.

     THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
     IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
     FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
     AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
     LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
     OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
     SOFTWARE.

EOF
}

#------------------------------------------------------------------------
# Function: _pg_setup_colors         Colors (tput â†’ ANSI â†’ none)
# Purpose : make stuff pretty also safe for diff setups
#------------------------------------------------------------------------
_pg_setup_colors() {
    if command -v tput &>/dev/null && [[ $(tput colors 2>/dev/null) -ge 8 ]]; then
        __PG_RED=$(tput setaf 1)
        __PG_GREEN=$(tput setaf 2)
        __PG_CYAN=$(tput setaf 6)
        __PG_YELLOW=$(tput setaf 11)
        __PG_BPURP=$(tput setaf 13)
        __PG_GREY=$(tput setaf 245)
        __PG_RESET=$(tput sgr0)
        __PG_UNLINE=$(tput smul)
        __PG_STOPUNLINE=$(tput rmul)
    else
        __PG_RED='\033[31m'
        __PG_GREEN='\033[32m'
        __PG_CYAN='\033[36m'
        __PG_YELLOW='\033[93m'
        __PG_BPURP='\033[95m'
        __PG_GREY='\033[90m'
        __PG_RESET='\033[0m'
        __PG_UNLINE='\033[4m'
        __PG_STOPUNLINE='\033[24m'   
    fi

    # Ensure variables are always set
    : "${__PG_RED:=}"
    : "${__PG_GREEN:=}"
    : "${__PG_CYAN:=}"
    : "${__PG_YELLOW:=}"
    : "${__PG_BPURP:=}"
    : "${__PG_GREY:=}"
    : "${__PG_RESET:=}"
    : "${__PG_UNLINE:=}"
    : "${__PG_STOPUNLINE:=}"
}

#------------------------------------------------------------------------
# Function: _pg_bash_ver_check
# Purpose : Enforce minimum Bash version
# Bash 4.4+ is required for associative arrays and namerefs.
#------------------------------------------------------------------------
_pg_bash_ver_check() {
    local MIN_BASH_MAJOR=4
    local MIN_BASH_MINOR=4
    local CURRENT_BASH_MAJOR=${BASH_VERSINFO[0]}
    local CURRENT_BASH_MINOR=${BASH_VERSINFO[1]}

    if (( CURRENT_BASH_MAJOR < MIN_BASH_MAJOR )) || \
       (( CURRENT_BASH_MAJOR == MIN_BASH_MAJOR && CURRENT_BASH_MINOR < MIN_BASH_MINOR )); then
        printf "Error: Bash %d.%d or higher is required for 'ct'. You are using %d.%d.\n" \
            "$MIN_BASH_MAJOR" "$MIN_BASH_MINOR" "$CURRENT_BASH_MAJOR" "$CURRENT_BASH_MINOR" >&2
        printf "Please upgrade your Bash version to use this script.\n" >&2
        return 1
    fi
}

#------------------------------------------------------------------------
# Function: _pg_conflicts       Command Resolution & Shadowing Report    
# Purpose : list all commands that conflict with other command names
#------------------------------------------------------------------------
_pg_conflicts() {                            
    
    _pg_setup_colors

#    printf "Examining Conflicting Command Names:\n"
    printf "Command Resolution & Shadowing Report:\n" 
    printf "This may take a moment\n\n" 
    _pg_keyword_conflicts
    _pg_alias_conflicts
    _pg_function_conflicts
    _pg_builtin_conflicts
}

#------------------------------------------------------------------------
# Function: _pg_keyword_conflicts
# Purpose : list all shell keywords that conflict with other command names
#------------------------------------------------------------------------
_pg_keyword_conflicts() {
    local kw kinds winner
    printf "Keywords \n"

    while IFS= read -r kw; do
        declare -A RES
        declare -a PATH_ENTRIES

        _pg_resolve "$kw" RES PATH_ENTRIES

        kinds=()

        [[ ${RES[alias_found]} == true ]] && kinds+=("alias")
        [[ ${RES[function_found]} == true ]] && kinds+=("function")
        [[ ${RES[builtin_found]} == true ]] && kinds+=("builtin")
      
        # Detect external presence
        local has_external=false
        for entry in "${PATH_ENTRIES[@]}"; do
            IFS='|' read -r _ state _ _ <<<"$entry"
            if [[ "$state" != "notfound" ]]; then
                has_external=true
                break
            fi
        done
        [[ $has_external == true ]] && kinds+=("external")
        
        # determine winner using resolver
        winner="${RES[bash_type]}"
        [[ "$winner" == "path" ]] && winner="external"
        
        
        
        if ((${#kinds[@]} > 0)); then
            printf "  Keyword: ${__PG_CYAN}%-11s${__PG_RESET}\n" "$kw"
            
            if [[ "$winner" == "keyword" ]]; then
                printf "     â†ł Also defined as: %s\n\n" \
                    "$(_pg_format_kinds "" "${kinds[@]}")"
            else
                printf "     â†ł Also defined as: %s\n\n" \
                    "$(_pg_format_kinds "$winner" "${kinds[@]}")"
            fi
        fi
    done < <(compgen -k)

    printf "\n"
}

#------------------------------------------------------------------------
# Function: _pg_alias_conflicts
# Purpose : list all aliases that conflict with other command names
#------------------------------------------------------------------------
_pg_alias_conflicts() {
    local acmd kinds winner
    printf "Aliases \n"

    while IFS= read -r acmd; do
        declare -A RES
        declare -a PATH_ENTRIES

        _pg_resolve "$acmd" RES PATH_ENTRIES

        kinds=()

        # collect other kinds (exclude alias itself)
        [[ ${RES[function_found]} == true ]] && kinds+=("function")
        [[ ${RES[builtin_found]} == true ]]  && kinds+=("builtin")
        [[ ${RES[keyword_found]} == true ]]  && kinds+=("keyword")

        # detect external presence (not just winner)
        local has_external=false
        for entry in "${PATH_ENTRIES[@]}"; do
            IFS='|' read -r _ state _ _ <<<"$entry"
            if [[ "$state" != "notfound" ]]; then
                has_external=true
                break
            fi
        done
        [[ $has_external == true ]] && kinds+=("external")
 
        # determine winner using resolver
        winner="${RES[bash_type]}"
        [[ "$winner" == "path" ]] && winner="external"

        local display_winner="$winner"
        if [[ "$winner" != "alias" ]]; then
            display_winner="${__PG_YELLOW}${winner}${__PG_RESET}"
        fi

        # only show real conflicts
        if ((${#kinds[@]} > 0)); then
            printf "  Alias: ${__PG_CYAN}%-13s${__PG_RESET}\n" "$acmd"
            printf "     â†ł Also defined as: %s\n" \
                "$(_pg_format_kinds "$winner" "${kinds[@]}")"
            printf "     â†ł Resolution:      %s wins\n\n" "$display_winner"
        fi

    done < <(alias | sed -E 's/^alias ([^=]+)=.*/\1/')

    printf "\n"
}

#------------------------------------------------------------------------
# Function: _pg_function_conflicts
# Purpose : list all shell functions that conflict with other command names
#------------------------------------------------------------------------
_pg_function_conflicts() {
    local fname kinds winner
    printf "Functions \n"

    while IFS= read -r fname; do
        declare -A RES
        declare -a PATH_ENTRIES

        _pg_resolve "$fname" RES PATH_ENTRIES

        kinds=()

        # collect other kinds (exclude function itself)
        [[ ${RES[alias_found]} == true ]]   && kinds+=("alias")
        [[ ${RES[keyword_found]} == true ]] && kinds+=("keyword")
        [[ ${RES[builtin_found]} == true ]]  && kinds+=("builtin")
        
        # detect external presence (not just winner)
        local has_external=false
        for entry in "${PATH_ENTRIES[@]}"; do
            IFS='|' read -r _ state _ _ <<<"$entry"
            if [[ "$state" != "notfound" ]]; then
                has_external=true
                break
            fi
        done
        [[ $has_external == true ]] && kinds+=("external")
 
        # determine winner using resolver
        winner="${RES[bash_type]}"
        [[ "$winner" == "path" ]] && winner="external"

        local display_winner="$winner"
        if [[ "$winner" != "function" ]]; then
            display_winner="${__PG_YELLOW}${winner}${__PG_RESET}"
        fi

        # only show real conflicts
        if ((${#kinds[@]} > 0)); then
            printf "  Function: ${__PG_CYAN}%-10s${__PG_RESET}\n" "$fname"
            printf "     â†ł Also defined as: %s\n" \
                 "$(_pg_format_kinds "$winner" "${kinds[@]}")"
            printf "     â†ł Resolution:      %s wins\n\n" "$display_winner"
        fi

    done < <(declare -F | awk '{print $3}')

    printf "\n"
}

#------------------------------------------------------------------------
# Function: _pg_builtin_conflicts
# Purpose : list all builtins that conflict with other command names
#------------------------------------------------------------------------
_pg_builtin_conflicts() {
    local bcmd kinds winner
    
    printf "Builtins \n"

    while IFS= read -r bcmd; do
        declare -A RES
        declare -a PATH_ENTRIES

        _pg_resolve "$bcmd" RES PATH_ENTRIES

        kinds=()

        # collect other kinds (exclude builtin itself)
        [[ ${RES[alias_found]} == true ]]    && kinds+=("alias")
        [[ ${RES[function_found]} == true ]] && kinds+=("function")
        [[ ${RES[keyword_found]} == true ]]  && kinds+=("keyword")
        
        # builtin state comes from resolver (not enable parsing)
        local enabled_state="${RES[builtin_state]}"
        [[ "$enabled_state" == "disabled" ]] && enabled_state="(disabled)"
        
        # detect external presence (not just winner)
        local has_external=false
        for entry in "${PATH_ENTRIES[@]}"; do
            IFS='|' read -r _ state _ _ <<<"$entry"
            if [[ "$state" != "notfound" ]]; then
                has_external=true
                break
            fi
        done
        [[ $has_external == true ]] && kinds+=("external")

        # determine winner
        winner="${RES[bash_type]}"
        [[ "$winner" == "path" ]] && winner="external"

        local display_winner="$winner"
        if [[ "$winner" != "builtin" ]]; then
            display_winner="${__PG_YELLOW}${winner}${__PG_RESET}"
        fi

        # only show real conflicts
        if ((${#kinds[@]} > 0)); then
            printf "  Builtin: ${__PG_CYAN}%-12s${__PG_RESET} %s\n" "$bcmd" "$enabled_state"
            printf "     â†ł Also defined as: %s\n" \
                "$(_pg_format_kinds "$winner" "${kinds[@]}")"
            printf "     â†ł Resolution:      %s wins\n\n" "$display_winner"
        fi

    done < <(compgen -b)

    printf "\n"
}

#------------------------------------------------------------------------
# Function: _pg_format_kinds
# Purpose : format output for consistency
#------------------------------------------------------------------------
_pg_format_kinds() {
    local winner="$1"
    shift

    local seen=()
    local ordered=()
    local k base note

    for k in "$@"; do
        base="${k%%(*}"
        note=""

        if [[ "$base" != "$winner" ]]; then
            note="(shadowed)"
        fi

        k="$base$note"

        [[ ! " ${seen[*]} " =~ " $k " ]] && seen+=("$k")
    done

    local order=(alias function builtin keyword external)
    for o in "${order[@]}"; do
        for s in "${seen[@]}"; do
            [[ "$s" == "$o"* ]] && ordered+=("$s")
        done
    done

    (IFS=", "; echo "${ordered[*]}")
}
#------------------------------------------------------------------------
# End of script
